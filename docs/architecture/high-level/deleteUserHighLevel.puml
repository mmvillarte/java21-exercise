@startuml DeleteUserHighLevel

actor User
participant "User API" as API
participant "User Service" as Service
database DB

User -> API : Delete user request
API -> Service : deleteUser(id)

Service -> DB : find user by id

alt User exists
    Service -> DB : delete user
    Service --> API : success
    API --> User : 204 No Content
else User not found
    Service --> API : error
    API --> User : 404 Not Found
end

@enduml